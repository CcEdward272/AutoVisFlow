<Window x:Class="Cc.IDE.Player.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Cc.IDE.Player"
        Title="Cc.IDE Player — 操作员界面"
        Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E" Foreground="#D4D4D4">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#007ACC" Padding="15,10">
            <Grid>
                <TextBlock Text="Cc.IDE Player" FontSize="24" FontWeight="Bold" Foreground="White"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding StationId, StringFormat='工位: {0}'}"
                               Foreground="White" Margin="10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding OperatorName, StringFormat='操作员: {0}'}"
                               Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Run Control Bar -->
        <Border Grid.Row="1" Background="#2D2D2D" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="▶ 开始测试" Width="120" Height="40" Margin="5"
                        Background="#007ACC" Foreground="White" FontSize="16" FontWeight="Bold"
                        Command="{Binding StartCommand}"
                        IsEnabled="{Binding IsNotRunning}"/>
                <Button Content="⏹ 停止" Width="80" Height="40" Margin="5"
                        Background="#D32F2F" Foreground="White" FontSize="14"
                        Command="{Binding StopCommand}"
                        IsEnabled="{Binding IsRunning}"/>
                <Button Content="⏸ 暂停" Width="80" Height="40" Margin="5"
                        Background="#FFA000" Foreground="White" FontSize="14"
                        Command="{Binding PauseCommand}"
                        IsEnabled="{Binding IsRunning}"/>
                <Separator Width="30" Background="Transparent"/>
                <TextBlock Text="序列号:" VerticalAlignment="Center" Margin="5,0"/>
                <TextBox Width="200" Height="30" VerticalAlignment="Center"
                         Background="#3C3C3C" Foreground="White" BorderBrush="#555"
                         Text="{Binding SerialNumber, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </Border>

        <!-- Results Area -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Summary Stats -->
            <Border Grid.Row="0" Background="#2D2D2D" Padding="10" Margin="0,0,0,10" CornerRadius="4">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock FontSize="20" Margin="20,0" FontWeight="Bold" Foreground="#4CAF50">
                        <Run Text="通过: "/><Run Text="{Binding PassedCount}"/>
                    </TextBlock>
                    <TextBlock FontSize="20" Margin="20,0" FontWeight="Bold" Foreground="#F44336">
                        <Run Text="失败: "/><Run Text="{Binding FailedCount}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding TotalCount, StringFormat='总计: {0}'}"
                               Foreground="#D4D4D4" FontSize="20" Margin="20,0"/>
                    <TextBlock Text="{Binding PassRateText}"
                               Foreground="#FFA000" FontSize="20" Margin="20,0" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Results Table -->
            <Border Grid.Row="1" Background="#252526" BorderBrush="#3F3F46" BorderThickness="1">
                <ListView Background="#252526" Foreground="#D4D4D4"
                          ItemsSource="{Binding Results}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="时间" Width="100"
                                            DisplayMemberBinding="{Binding Time}"/>
                            <GridViewColumn Header="序列号" Width="150"
                                            DisplayMemberBinding="{Binding SerialNumber}"/>
                            <GridViewColumn Header="任务" Width="180"
                                            DisplayMemberBinding="{Binding TaskName}"/>
                            <GridViewColumn Header="结果" Width="80"
                                            DisplayMemberBinding="{Binding Result}"/>
                            <GridViewColumn Header="耗时" Width="80"
                                            DisplayMemberBinding="{Binding Duration}"/>
                            <GridViewColumn Header="详情" Width="200"
                                            DisplayMemberBinding="{Binding Detail}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="3" Background="#007ACC" Foreground="White">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Margin="8,0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding PlcStatusText}" Margin="8,0"/>
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding InstrumentStatusText}" Margin="8,0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
