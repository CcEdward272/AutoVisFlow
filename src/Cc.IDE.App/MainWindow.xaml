<Window x:Class="Cc.IDE.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Cc.IDE.App"
        xmlns:task="clr-namespace:Cc.IDE.TaskEditor;assembly=Cc.IDE.TaskEditor"
        Title="Cc.IDE — PLC 测控开发环境"
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#252526">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu + Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Vertical">
            <Menu Background="#3C3C3C" Foreground="#D4D4D4">
                <MenuItem Header="文件(_F)">
                    <MenuItem Header="新建解决方案(_N)" InputGestureText="Ctrl+N"/>
                    <MenuItem Header="打开解决方案(_O)" InputGestureText="Ctrl+O"/>
                    <Separator/>
                    <MenuItem Header="保存(_S)" InputGestureText="Ctrl+S"/>
                    <MenuItem Header="全部保存(_A)" InputGestureText="Ctrl+Shift+S"/>
                    <Separator/>
                    <MenuItem Header="退出(_X)" InputGestureText="Alt+F4"/>
                </MenuItem>
                <MenuItem Header="编辑(_E)">
                    <MenuItem Header="撤销(_U)" InputGestureText="Ctrl+Z"
                              Command="{Binding FlowCanvas.UndoCommand}"/>
                    <MenuItem Header="重做(_R)" InputGestureText="Ctrl+Y"
                              Command="{Binding FlowCanvas.RedoCommand}"/>
                </MenuItem>
                <MenuItem Header="视图(_V)">
                    <MenuItem Header="解决方案资源管理器"
                              IsCheckable="True" IsChecked="{Binding IsSolutionExplorerVisible}"/>
                    <MenuItem Header="工具箱"
                              IsCheckable="True" IsChecked="{Binding IsToolboxVisible}"/>
                    <MenuItem Header="属性"
                              IsCheckable="True" IsChecked="{Binding IsPropertyPaneVisible}"/>
                    <MenuItem Header="输出"
                              IsCheckable="True" IsChecked="{Binding IsOutputPaneVisible}"/>
                </MenuItem>
                <MenuItem Header="运行(_R)">
                    <MenuItem Header="▶ 运行(_R)" InputGestureText="F5"
                              Command="{Binding StartCommand}"/>
                    <MenuItem Header="⏹ 停止(_S)" InputGestureText="Shift+F5"
                              Command="{Binding StopCommand}"/>
                    <MenuItem Header="⏸ 暂停(_P)"
                              Command="{Binding PauseCommand}"/>
                </MenuItem>
                <MenuItem Header="调试(_D)">
                    <MenuItem Header="切换断点" InputGestureText="F9"/>
                    <MenuItem Header="单步执行" InputGestureText="F10"/>
                </MenuItem>
                <MenuItem Header="工具(_T)">
                    <MenuItem Header="仪器管理器"/>
                    <MenuItem Header="IO 映射编辑器"/>
                </MenuItem>
                <MenuItem Header="帮助(_H)">
                    <MenuItem Header="关于"/>
                </MenuItem>
            </Menu>
            <ToolBar Background="#2D2D2D">
                <Button Content="▶ 运行" Margin="2"
                        Command="{Binding StartCommand}"
                        Background="#007ACC" Foreground="White"
                        Width="80" Height="28"/>
                <Button Content="⏹ 停止" Margin="2"
                        Command="{Binding StopCommand}"
                        Background="#D32F2F" Foreground="White"
                        Width="80" Height="28"/>
                <Button Content="⏸ 暂停" Margin="2"
                        Command="{Binding PauseCommand}"
                        Background="#FFA000" Foreground="White"
                        Width="80" Height="28"/>
                <Separator/>
                <Button Content="撤销" Margin="2"
                        Command="{Binding FlowCanvas.UndoCommand}"
                        Width="60" Height="28"/>
                <Button Content="重做" Margin="2"
                        Command="{Binding FlowCanvas.RedoCommand}"
                        Width="60" Height="28"/>
            </ToolBar>
        </StackPanel>

        <!-- Main content area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="150"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="260" MinWidth="150"/>
            </Grid.ColumnDefinitions>

            <!-- Solution Explorer with TreeView -->
            <Border Grid.Column="0" Background="#252526"
                    BorderBrush="#3F3F46" BorderThickness="0,0,1,0"
                    Visibility="{Binding IsSolutionExplorerVisible, Converter={x:Static local:MainWindow.BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#2D2D2D" Padding="10,8"
                            BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                        <TextBlock Text="解决方案资源管理器" Foreground="#D4D4D4"
                                   FontWeight="Bold" FontSize="13"/>
                    </Border>
                    <TreeView Grid.Row="1" x:Name="SolutionTree"
                              Background="Transparent" Foreground="#D4D4D4"
                              BorderThickness="0" Margin="4,4"
                              ItemsSource="{Binding SolutionExplorer.RootNode.Children}">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded}"/>
                                <Setter Property="IsSelected" Value="{Binding IsSelected}"/>
                                <Setter Property="Foreground" Value="#D4D4D4"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type local:SolutionTreeNode}"
                                                      ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="{Binding DisplayIcon}" Margin="0,0,4,0"
                                               Foreground="{Binding IconColor}"/>
                                    <TextBlock Text="{Binding Name}"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Document area: FlowCanvas -->
            <Border Grid.Column="1" Background="#1E1E1E">
                <task:FlowCanvas x:Name="FlowCanvasControl"
                                 DataContext="{Binding FlowCanvas}"/>
            </Border>

            <!-- Right panel: Toolbox + Property Pane -->
            <Grid Grid.Column="2"
                  Visibility="{Binding IsToolboxVisible, Converter={x:Static local:MainWindow.BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <task:ToolboxView Grid.Row="0" DataContext="{Binding Toolbox}"/>
                <GridSplitter Grid.Row="1" Height="4" Background="#555" HorizontalAlignment="Stretch"/>
                <task:PropertyPaneView Grid.Row="2" DataContext="{Binding FlowCanvas}"
                                       Visibility="{Binding IsPropertyPaneVisible, Converter={x:Static local:MainWindow.BoolToVis}}"/>
            </Grid>
        </Grid>

        <!-- Output Panel -->
        <Border Grid.Row="2" x:Name="OutputPanel"
                Visibility="{Binding IsOutputPaneVisible, Converter={x:Static local:MainWindow.BoolToVis}}"
                Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="120"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#2D2D2D" Padding="10,6"
                        BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="TabLog" Content="运行日志" Foreground="#D4D4D4"
                                     IsChecked="True" Margin="0,0,12,0"
                                     GroupName="OutputTabs"/>
                        <RadioButton x:Name="TabComm" Content="通讯日志" Foreground="#D4D4D4"
                                     Margin="0,0,12,0" GroupName="OutputTabs"/>
                        <RadioButton x:Name="TabWarn" Content="告警" Foreground="#D4D4D4"
                                     Margin="0,0,12,0" GroupName="OutputTabs"/>
                        <RadioButton x:Name="TabDebug" Content="调试" Foreground="#D4D4D4"
                                     Margin="0,0,12,0" GroupName="OutputTabs"/>
                        <RadioButton x:Name="TabVars" Content="变量监视" Foreground="#D4D4D4"
                                     GroupName="OutputTabs"/>
                    </StackPanel>
                </Border>
                <TextBox Grid.Row="1" x:Name="OutputLog"
                         Background="#1E1E1E" Foreground="#AAA"
                         BorderThickness="0" IsReadOnly="True"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="12"
                         AcceptsReturn="True"/>
            </Grid>
        </Border>

        <!-- Status bar -->
        <StatusBar Grid.Row="3" Background="#007ACC" Foreground="White">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Margin="8,0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Margin="8,0">
                    <Run Text="PLC: "/>
                    <Run Text="{Binding PlcStatusText}" Foreground="{Binding PlcStatusColor}"/>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Margin="8,0">
                    <Run Text="CAN: "/>
                    <Run Text="{Binding CanStatusText}" Foreground="{Binding CanStatusColor}"/>
                </TextBlock>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Margin="8,0">
                    <Run Text="仪器: "/>
                    <Run Text="{Binding InstrumentStatusText}" Foreground="{Binding InstrumentStatusColor}"/>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
