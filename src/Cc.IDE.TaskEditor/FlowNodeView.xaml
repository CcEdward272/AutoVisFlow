<UserControl x:Class="Cc.IDE.TaskEditor.FlowNodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <SolidColorBrush x:Key="SelectedStroke" Color="#FFD700"/>
        <SolidColorBrush x:Key="PortFill" Color="#777"/>
        <SolidColorBrush x:Key="PortStroke" Color="#444"/>
        <SolidColorBrush x:Key="PortHover" Color="#FFD700"/>
    </UserControl.Resources>

    <Grid>
        <!-- 节点主体 -->
        <Border x:Name="NodeBorder"
                Width="{Binding Width}" Height="{Binding Height}"
                BorderThickness="2" CornerRadius="6"
                Background="#2D2D2D" BorderBrush="#555"
                ToolTip="{Binding Description}">
            <Grid>
                <Border x:Name="TitleBar" Height="22" VerticalAlignment="Top"
                        CornerRadius="4,4,0,0" Background="#444">
                    <TextBlock Text="{Binding DisplayTitle}" Foreground="White"
                               FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               TextTrimming="CharacterEllipsis" Margin="4,0"/>
                </Border>
                <TextBlock Text="{Binding NodeType, StringFormat='[{0}]'}"
                           Foreground="#999" FontSize="9"
                           VerticalAlignment="Bottom" HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
            </Grid>
        </Border>

        <!-- ===== 输入端口（左中）===== -->
        <Grid x:Name="InputPortGrid"
              HorizontalAlignment="Left" VerticalAlignment="Center"
              Margin="-10,0,0,0"
              Cursor="Cross" Visibility="Visible">
            <!-- 透明大热区 20x20 -->
            <Ellipse Width="20" Height="20" Fill="Transparent" Stroke="Transparent"
                     x:Name="InputPortHit"/>
            <!-- 可视圆点 12x12 -->
            <Ellipse Width="12" Height="12" Fill="#777" Stroke="#444" StrokeThickness="1.5"/>
        </Grid>

        <!-- ===== 输出端口 1（右中，默认）===== -->
        <Grid x:Name="OutputPortGrid1"
              HorizontalAlignment="Right" VerticalAlignment="Center"
              Margin="0,0,-10,0"
              Cursor="Cross" Visibility="Visible">
            <Ellipse Width="20" Height="20" Fill="Transparent" Stroke="Transparent"
                     x:Name="OutputPortHit1"/>
            <Ellipse Width="12" Height="12" Fill="#777" Stroke="#444" StrokeThickness="1.5"/>
            <!-- 端口标签 -->
            <TextBlock Text="" FontSize="7" Foreground="#888"
                       HorizontalAlignment="Center" VerticalAlignment="Bottom"
                       Margin="0,0,0,-10"/>
        </Grid>

        <!-- ===== 输出端口 2（右上，条件节点 False 分支）===== -->
        <Grid x:Name="OutputPortGrid2"
              HorizontalAlignment="Right" VerticalAlignment="Top"
              Margin="0,8,-10,0"
              Cursor="Cross" Visibility="Collapsed">
            <Ellipse Width="20" Height="20" Fill="Transparent" Stroke="Transparent"
                     x:Name="OutputPortHit2"/>
            <Ellipse Width="12" Height="12" Fill="#C62828" Stroke="#B71C1C" StrokeThickness="1.5"/>
            <TextBlock Text="F" FontSize="8" Foreground="#FFCDD2"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- 选中高亮 -->
        <Border x:Name="SelectionBorder"
                BorderBrush="{StaticResource SelectedStroke}"
                BorderThickness="0" CornerRadius="7"
                Visibility="Collapsed"/>
    </Grid>
</UserControl>
