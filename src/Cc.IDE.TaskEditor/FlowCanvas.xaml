<UserControl x:Class="Cc.IDE.TaskEditor.FlowCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Cc.IDE.TaskEditor"
             Focusable="True"
             Background="#1E1E1E">

    <Grid>
        <!-- 主画布：所有内容都在同一个 Canvas 上，坐标系一致 -->
        <Canvas x:Name="MainCanvas" Background="Transparent"
                ClipToBounds="True" AllowDrop="True"/>

        <!-- 选择框（画布上方叠加） -->
        <Border x:Name="SelectionRect"
                BorderBrush="#FFD700"
                BorderThickness="1"
                Background="#20FFD700"
                Visibility="Collapsed"
                IsHitTestVisible="False"/>

        <!-- MiniMap 小地图 -->
        <Border x:Name="MiniMap"
                Width="180" Height="120"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,10,10"
                Background="#BB2D2D2D"
                BorderBrush="#555"
                BorderThickness="1" CornerRadius="4">
            <TextBlock Text="概览" Foreground="#666" FontSize="10"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- 缩放指示器 -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Background="#BB2D2D2D" BorderBrush="#555"
                BorderThickness="1" CornerRadius="4"
                Padding="8,4" Margin="10,0,0,10">
            <TextBlock x:Name="ZoomIndicator" Foreground="#AAA" FontSize="11" Text="100%"/>
        </Border>
    </Grid>
</UserControl>
