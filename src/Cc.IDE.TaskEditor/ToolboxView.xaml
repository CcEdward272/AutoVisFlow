<UserControl x:Class="Cc.IDE.TaskEditor.ToolboxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Cc.IDE.TaskEditor"
             Background="#252526">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D2D" Padding="10,8"
                BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
            <TextBlock Text="工具箱" Foreground="#D4D4D4"
                       FontWeight="Bold" FontSize="13"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="CategoryList" Margin="4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander Header="{Binding CategoryName}"
                                  Foreground="#D4D4D4"
                                  Background="#2D2D2D"
                                  BorderBrush="#3F3F46"
                                  IsExpanded="True"
                                  Margin="0,2">
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#333"
                                                BorderBrush="#444"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Padding="8,5"
                                                Margin="2,1"
                                                Cursor="Hand"
                                                ToolTip="{Binding Tooltip}"
                                                MouseLeftButtonDown="OnItemMouseDown"
                                                MouseMove="OnItemMouseMove">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="16" Height="16"
                                                        Background="#555" CornerRadius="2"
                                                        Margin="0,0,6,0"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding DisplayName}"
                                                           Foreground="#D4D4D4"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
